/* coron.keymap — Gemini concept adapted for coron / Mac JIS
 *
 * Layer map:
 *   0 BASE   — default typing
 *   1 NAV    — arrows, home/end, undo/cut/copy/paste  (SPACE hold / MUHENKAN hold / ENTER hold)
 *   2 NUM    — numpad, symbols (JIS-correct)           (SPACE hold)
 *   3 (reserved)
 *   4 MOUSE  — auto-activated by trackball              (hardware: automouse-layer = 4)
 *   5 SCROLL — auto-activated for scroll                (hardware: scroll-layers   = 5)
 *   6 SYS    — F-keys, BT, volume, bootloader          (HENKAN hold)
 *
 * Thumb cluster (row 3, positions 4-8):
 *   pos4 HENKAN   hold → SYS(6),  tap → INT_HENKAN  (→layer0 + HEN)
 *   pos5 SPACE    hold → NUM(2),  tap → SPACE
 *   pos6 MUHENKAN hold → NAV(1),  tap → INT_MUHENKAN (→layer0 + MUH)
 *   pos7 BSPC
 *   pos8 ENTER    hold → NAV(1),  tap → ENTER
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/pointing.h>

/* ── Layer aliases ─────────────────────────────────────────── */
#define BASE   0
#define NAV    1
#define NUM    2
#define MOUSE  4
#define SCROLL 5
#define SYS    6

/* ── Global behaviour tweaks ───────────────────────────────── */
&mt {
    flavor = "balanced";
    quick-tap-ms = <0>;
};

&trackball {
    automouse-layer = <MOUSE>;   /* = 4 */
    scroll-layers   = <SCROLL>;  /* = 5 */
};

/ {
    /* ── Combos ─────────────────────────────────────────────── */
    combos {
        compatible = "zmk,combos";

        /* Key-position index reference (flat, 0-based):
         *  Row0(13): 0-12    Row1(14): 13-26
         *  Row2(14): 27-40   Row3(11): 41-51
         *
         *  11=P  12=BSPC  13=TAB  14=A
         *  21=H  22=J     25=SQT  26=ENTER
         */
        tab {
            bindings = <&kp TAB>;
            key-positions = <12 13>;
        };

        shift_tab {
            bindings = <&kp LS(TAB)>;
            key-positions = <13 14>;
        };

        muhennkann {
            bindings = <&to_layer_0 INT_MUHENKAN>;
            key-positions = <11 12>;
        };

        double_quotation {
            bindings = <&kp DOUBLE_QUOTES>;
            key-positions = <21 22>;
        };

        eq {
            bindings = <&kp EQUAL>;
            key-positions = <25 26>;
        };
    };

    /* ── Macros ──────────────────────────────────────────────── */
    macros {
        /* Reset to layer 0 then send one keycode (for JIS IME keys) */
        to_layer_0: to_layer_0 {
            compatible = "zmk,behavior-macro-one-param";
            #binding-cells = <1>;
            bindings = <&to 0 &macro_param_1to1 &kp MACRO_PLACEHOLDER>;
            label = "TO_LAYER_0";
        };

        /* Screenshot to clipboard: Cmd+Shift+4 */
        ss_clip: ss_clip {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings = <&kp LG(LS(N4))>;
            label = "SS_CLIP";
        };
    };

    /* ── Custom behaviours ───────────────────────────────────── */
    behaviors {
        /* Hold: mo <layer>   Tap: to_layer_0 <key>  (for HENKAN/MUHENKAN) */
        lt_to_layer_0: lt_to_layer_0 {
            compatible = "zmk,behavior-hold-tap";
            label = "LAYER_TAP_TO_0";
            bindings = <&mo>, <&to_layer_0>;
            #binding-cells = <2>;
            tapping-term-ms = <200>;
        };

        /* Encoder: rotate → scroll down / up */
        scroll_encoder: scroll_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_DOWN>, <&msc SCRL_UP>;
        };
    };

    /* ── Keymap ──────────────────────────────────────────────── */
    keymap {
        compatible = "zmk,keymap";

        /* ══════════════════════════════════════════════════════
         * Layer 0 — BASE
         * ══════════════════════════════════════════════════════
         * Row 0 (13): ESC  Q  W  E  R  T  [MUTE]  Y  U  I  O  P  BSPC
         * Row 1 (14): TAB  A  S  D  F  G  [SS] [-]  H  J  K  L  :(SQT) RET
         * Row 2 (14): LSft Z  X  C  V  B  [:] [;]   N  M  ,  .  /  RSft
         * Row 3 (11): CAPS CTL ALT WIN HEN SPC MUH  BSPC RET  MC  RO
         *
         * JIS Mac notes:
         *   SQT  → :   SEMI → ;   MINUS → -
         *   Lt 5 I activates SCROLL layer (encoder scroll mode)
         */
        base_layer {
            bindings = <
&kp ESC        &kp Q             &kp W        &kp E        &kp R                        &kp T        &kp C_MUTE                    &kp Y          &kp U        &lt SCROLL I &kp O    &kp P           &kp BACKSPACE
&kp TAB        &kp A             &kp S        &kp D        &kp F                        &kp G        &ss_clip                      &kp MINUS      &kp H        &kp J        &kp K    &kp L           &kp SQT        &kp ENTER
&kp LEFT_SHIFT &mt LEFT_SHIFT Z  &kp X        &kp C        &kp V                        &kp B        &kp SQT                       &kp SEMICOLON  &kp N        &kp M        &kp COMMA &kp DOT        &kp SLASH      &kp RIGHT_SHIFT
&kp CAPS       &kp LCTRL         &kp LEFT_ALT &kp LEFT_WIN &lt_to_layer_0 SYS INT_HENKAN &lt NUM SPACE &lt_to_layer_0 NAV INT_MUHENKAN &kp BACKSPACE &lt NAV ENTER &kp LC(UP_ARROW) &kp INT_RO
            >;

            sensor-bindings = <&scroll_encoder>;
        };

        /* ══════════════════════════════════════════════════════
         * Layer 1 — NAV   (SPACE hold / MUHENKAN hold / ENTER hold)
         * ══════════════════════════════════════════════════════
         * Row 0: ---  Q(Cmd) W(Cmd) ---  ---  ---  ---  HOME PgDn UP  PgUp END  ---
         * Row 1: ---  ---    ---    ---  ---  MCtl ---  ---  LEFT DOWN UP   RIGH ---  ---
         * Row 2: ---  Undo   Cut    Copy Paste ---  ---  ---  ---  ---  ---  ---  ---  ---
         * Row 3: all trans
         *
         * Mac shortcuts: LG(Z)=Undo  LG(X)=Cut  LG(C)=Copy  LG(V)=Paste
         *   LC(LS(TAB)) / LC(TAB) = prev/next browser tab
         */
        nav_layer {
            bindings = <
&trans &kp LG(Q)  &kp LG(W)      &trans    &trans         &trans      &trans &kp HOME     &kp PG_DN &kp UP_ARROW   &kp PG_UP   &kp END       &trans
&trans &trans     &trans         &trans    &trans          &kp LC(UP_ARROW) &trans &trans  &kp LEFT_ARROW &kp DOWN_ARROW &kp UP_ARROW &kp RIGHT_ARROW &trans &trans
&trans &kp LG(Z)  &kp LG(X)      &kp LG(C) &kp LG(V)     &trans      &trans &trans       &trans    &trans         &trans      &trans        &trans &trans
&trans &trans     &trans         &trans    &trans          &trans      &trans &trans       &trans    &trans         &trans
            >;

            sensor-bindings = <&inc_dec_kp UP_ARROW DOWN_ARROW>;
        };

        /* ══════════════════════════════════════════════════════
         * Layer 2 — NUM   (SPACE hold)
         * ══════════════════════════════════════════════════════
         * Numpad on left, JIS-corrected symbols on right.
         *
         * JIS Mac symbol map used here:
         *   EQUAL      → ^      LS(EQUAL)    → ~
         *   LEFT_BRACKET  → @   LS(LEFT_BRACKET)  → `
         *   RIGHT_BRACKET → [   LS(RIGHT_BRACKET) → {
         *   BSLH (NON_US_HASH sibling) → ]
         *   INT_YEN    → \      LS(INT_YEN)  → |
         *   AMPERSAND  = LS(6) → & ✓  (ANSI Shift+6 = JIS Shift+6 = &)
         *   EXCLAMATION = LS(1)→ ! ✓
         *   HASH  = LS(3) → # ✓   DOLLAR = LS(4) → $ ✓  PERCENT = LS(5) → % ✓
         *   LS(N8) → (   LS(N9) → )
         */
        num_layer {
            bindings = <
&trans &kp MINUS                  &kp KP_NUMBER_7 &kp KP_NUMBER_8 &kp KP_NUMBER_9 &kp PLUS     &trans                   &kp EQUAL              &kp AMPERSAND        &kp TILDE            &kp LS(N8)             &kp LS(N9)           &trans
&trans &kp SLASH                  &kp KP_NUMBER_4 &kp KP_NUMBER_5 &kp KP_NUMBER_6 &kp ASTERISK &kp LC(LA(KP_NUMBER_0))  &kp INT_RO             &kp EXCLAMATION      &kp LEFT_BRACKET     &kp HASH               &kp DOLLAR           &kp PERCENT    &trans
&trans &mt LEFT_SHIFT KP_NUMBER_0 &kp KP_NUMBER_1 &kp KP_NUMBER_2 &kp KP_NUMBER_3 &kp PERIOD   &kp EQUAL                &trans                 &kp RIGHT_BRACKET    &kp NON_US_HASH      &kp LS(RIGHT_BRACKET)  &kp LS(NON_US_HASH)  &kp INT_YEN    &trans
&trans &trans                     &trans          &trans          &trans          &trans       &trans                   &trans                 &trans               &kp LS(INT_YEN)      &trans
            >;
        };

        /* ══════════════════════════════════════════════════════
         * Layer 3 — (reserved / empty)
         * ══════════════════════════════════════════════════════ */
        layer_3 {
            bindings = <
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans
            >;
        };

        /* ══════════════════════════════════════════════════════
         * Layer 4 — MOUSE   (auto-activated by trackball)
         * ══════════════════════════════════════════════════════ */
        mouse_layer {
            bindings = <
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans    &trans    &trans
&trans &trans &trans &trans &trans &trans &trans &trans &trans &mkp MB1 &mkp MB3 &mkp MB2 &trans &trans
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans    &trans    &trans    &trans &trans
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans    &trans
            >;
        };

        /* ══════════════════════════════════════════════════════
         * Layer 5 — SCROLL   (auto-activated; hold I to enter)
         * ══════════════════════════════════════════════════════ */
        scroll_layer {
            bindings = <
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans
&trans &trans &trans &trans &trans &trans &trans &trans &trans &trans &trans
            >;
        };

        /* ══════════════════════════════════════════════════════
         * Layer 6 — SYS   (HENKAN hold)
         * ══════════════════════════════════════════════════════
         * Row 0: ---  F1  F2  F3  F4  F5  ---  F6  F7  F8   F9   F10  ---
         * Row 1: ---  VolD VolU Mute BriD BriU --- ---  F11 F12  ---  ---  ---  ---
         * Row 2: ---  MC   SS   ---  ---  ---  --- ---  BT0 BT1  BT2  BT3  BTCLR ---
         * Row 3: ---  ---  ---  ---  ---  ---  --- ---  --- ---  BOOT
         *
         * MC  = Mission Control (LC(UP))
         * SS  = Screenshot clipboard (Cmd+Shift+4)
         * BT0-3 = Bluetooth profile select
         */
        sys_layer {
            bindings = <
&trans &kp F1           &kp F2       &kp F3          &kp F4      &kp F5      &trans &kp F6    &kp F7        &kp F8        &kp F9        &kp F10      &trans
&trans &kp C_VOL_DN     &kp C_VOL_UP &kp C_MUTE      &kp C_BRI_DN &kp C_BRI_UP &trans &trans &kp F11       &kp F12       &trans        &trans       &trans  &trans
&trans &kp LC(UP_ARROW) &kp LG(LS(N4)) &trans        &trans      &trans      &trans &trans    &bt BT_SEL 0  &bt BT_SEL 1  &bt BT_SEL 2  &bt BT_SEL 3 &bt BT_CLR &trans
&trans &trans           &trans       &trans          &trans      &trans      &trans &trans    &trans        &trans        &bootloader
            >;

            sensor-bindings = <&inc_dec_kp C_VOL_DN C_VOL_UP>;
        };
    };
};
